# Copy to .env and fill in. .env is gitignored.

# ── Infrastructure ────────────────────────────────────────────────
POSTGRES_PORT=5435
REDIS_PORT=6380
DATABASE_URL=postgres://orrery:orrery_local@localhost:5435/orrery
REDIS_URL=redis://localhost:6380

# ── Single-user auth (any long random string) ─────────────────────
ORRERY_AUTH_TOKEN=
ORRERY_SERVER_PORT=8787

# ── OpenSky (register at opensky-network.org → Account → API client)
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Set to 1 to permit anonymous OpenSky polling while credentials are absent
# or broken (400 credits/day instead of 4,000 — degraded, not steady state)
OPENSKY_ALLOW_ANONYMOUS=

# Raw poll snapshots for detector debugging (48h TTL). Default: <repo>/data/raw
RAW_DATA_DIR=

# ── adsb.fi — no key; base URL here so a fallback mirror is a config change
ADSBFI_BASE_URL=https://opendata.adsb.fi/api

# ── Analyst ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANALYST_TRIAGE_MODEL=claude-haiku-4-5-20251001
ANALYST_BRIEFING_MODEL=claude-sonnet-5
# infrastructure alerts (collector silent >30min) — separate from anomaly push
OPS_ALERTS_ENABLED=false
ANALYST_MONTHLY_SPEND_CAP_USD=10
ANALYST_WEB_SEARCHES_PER_DAY=10
BRIEFING_HOUR_LOCAL=7
BRIEFING_TIMEZONE=America/Denver

# ── Push (shadow mode: leave PUSH_ENABLED=false until the S1 log earns it)
PUSH_ENABLED=false
NTFY_TOPIC=
