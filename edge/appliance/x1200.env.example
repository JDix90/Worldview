# X1200 UPS monitor config — copy to x1200.env. NEVER commit the filled copy
# if you put a private ntfy topic in it.

# Ops alerts (the OPS/ntfy topic from the main .env; blank = log only)
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh

# Where docker-compose.yml lives on the Pi
COMPOSE_DIR=/home/pi/Project_Worldview

# Shutdown floors: two consecutive on-battery reads at/below either → clean stop
SOC_SHUTDOWN_PCT=15
VCELL_SHUTDOWN_V=3.0

# Power-loss-detect GPIO (X120x reference: GPIO6 — CONFIRM on-device by
# watching `pinctrl get 6` while plugging/unplugging before trusting it)
PLD_GPIO=6

POLL_SEC=10
