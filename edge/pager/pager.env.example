# ORRERY pager config — copy to pager.env and fill in. Loaded by the systemd
# unit via EnvironmentFile. NEVER commit the filled-in copy (it holds the token).

# The ORRERY backend — the Pi 5 appliance on the LAN (or the Mac during dev).
ORRERY_API_URL=http://orrery.local:8787
# Same static token the web client uses (must match the backend's ORRERY_AUTH_TOKEN).
ORRERY_AUTH_TOKEN=

# How often to pull the summary, seconds.
POLL_SEC=90

# Optional: instant S1/S2 nudges via the existing ntfy topic (SSE). Blank = off.
NTFY_TOPIC=
NTFY_URL=https://ntfy.sh
